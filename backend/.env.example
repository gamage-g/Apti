# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# PostgreSQL connection string
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:password@localhost:5432/engineiq

# DeepSeek API key
# Get yours at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-...

# DeepSeek model — verify the current name at https://api-docs.deepseek.com/quick_start/pricing
DEEPSEEK_MODEL=deepseek-chat

# CORS origins (comma-separated). Add your Vercel URL for production.
CORS_ORIGIN=http://localhost:5173

# VAPID keys for Web Push notifications.
# Generate a pair with: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print(v.private_pem().decode()); print(v.public_key.public_bytes_raw().hex())"
# Or use the web-push CLI: npx web-push generate-vapid-keys
#
# VAPID_PRIVATE_KEY: base64-encoded PEM (the full -----BEGIN EC PRIVATE KEY----- block, base64-encoded)
# VAPID_PUBLIC_KEY:  the raw uncompressed public key, base64url-encoded
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_MAILTO=mailto:your@email.com
